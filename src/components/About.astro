<script>
	const status = document.getElementById("time-status");

	const getStatusForHour = (hour) => {
		if (hour >= 22 || hour < 6) return "eppy";
		if (hour < 10) return "booting";
		if (hour < 13) return "locked_in";
		if (hour < 17) return "yapping";
		if (hour < 20) return "side_questing";
		return "winding_down";
	};

	const updateStatus = () => {
		if (!status) return;
		const now = new Date();
		status.textContent = getStatusForHour(now.getHours());
		status.title = `Updated from local time: ${now.toLocaleTimeString([], {
			hour: "2-digit",
			minute: "2-digit",
		})}`;
	};

	updateStatus();
	setInterval(updateStatus, 60 * 1000);
</script>
