---
const writings = [
	{
		title: "Misanthropic",
		date: "Feb 24, 2023",
		path: "2023/02/24/Misanthropic",
	},
	{
		title: "Morbid",
		date: "Feb 5, 2023",
		path: "2023/02/05/morbid",
	},
	{
		title: "Limerence",
		date: "Jan 26, 2023",
		path: "2023/01/26/January",
	},
];
---

<section id="writing" class="mx-auto mt-6 w-full max-w-3xl px-5 font-mono">
	<h2 class="mb-2 flex items-center gap-3 border border-dashed border-gray-500 bg-gray-50 px-3 py-2 text-sm font-bold text-black dark:border-zinc-500 dark:bg-zinc-900 dark:text-zinc-100">
		<span class="min-w-0 truncate">
			<span class="text-gray-500 dark:text-zinc-400">~/portfolio</span> $ tree writing/<span class="terminal-block-cursor" aria-hidden="true"></span>
		</span>
	</h2>

	<div class="border border-dashed border-gray-500 bg-gray-50 text-sm leading-relaxed text-gray-700 dark:border-zinc-500 dark:bg-zinc-900 dark:text-zinc-300">
		<div class="flex flex-wrap items-center justify-between gap-2 border-b border-dashed border-gray-400 px-3 py-2 text-xs font-bold text-gray-600 dark:border-zinc-600 dark:text-zinc-400">
			<span>root: blog.justagpt.xyz</span>
			<span>files: {writings.length}</span>
		</div>

		<div class="px-4 py-3">
			<div class="text-black dark:text-zinc-100">writing</div>
			<div class="text-gray-500 dark:text-zinc-500">├── thoughts</div>
			<div class="text-gray-500 dark:text-zinc-500">│&nbsp;&nbsp; └── 2023</div>
			{writings.map((post, index) => {
				const isLast = index === writings.length - 1;
				const branch = isLast ? "└──" : "├──";
				return (
					<div class="group flex gap-2 hover:bg-black hover:text-white dark:hover:bg-zinc-100 dark:hover:text-zinc-950">
						<span class="shrink-0 text-gray-500 group-hover:text-white dark:text-zinc-500 dark:group-hover:text-zinc-950">│&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; {branch}</span>
						<a
							href={`https://blog.justagpt.xyz/thoughts/${post.path}`}
							target="_blank"
							rel="noreferrer"
							class="min-w-0 flex-1"
						>
							<span class="font-bold text-black group-hover:text-white dark:text-zinc-100 dark:group-hover:text-zinc-950">
								{post.title}
							</span>
							<span class="text-gray-500 group-hover:text-white dark:text-zinc-400 dark:group-hover:text-zinc-950">
								{" "}
								-- {post.date}
							</span>
						</a>
					</div>
				);
			})}
			<div class="mt-2 text-xs font-bold text-gray-500 dark:text-zinc-500">
				click a leaf to open the thought
			</div>
		</div>
	</div>
</section>
