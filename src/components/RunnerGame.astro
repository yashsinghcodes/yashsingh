<section class="mx-auto mt-6 w-full max-w-3xl px-5 font-mono" aria-label="Asteroids mini game">
	<div class="mb-2 flex items-center gap-3 border border-dashed border-gray-500 bg-gray-50 px-3 py-2 font-mono text-sm font-bold text-black">
		<span class="min-w-0 truncate">
			<span class="text-gray-500">~/portfolio</span> $ ./asteroids<span class="terminal-block-cursor" aria-hidden="true"></span>
		</span>
	</div>
	<div class="border border-dashed border-gray-500 bg-gray-50">
		<div class="flex flex-wrap items-center justify-between gap-2 border-b border-dashed border-gray-400 px-3 py-2 text-xs font-bold text-gray-600">
			<span>mode: <span id="arcade-status">loading</span></span>
			<span>controls: arrows/wasd + space</span>
		</div>
		<canvas id="asteroids-game" class="block h-[220px] w-full cursor-pointer touch-manipulation md:h-[240px]" width="760" height="220"></canvas>
	</div>
</section>

<script>
	const canvas = document.getElementById("asteroids-game");
	const ctx = canvas?.getContext("2d");

	if (canvas && ctx) {
		const keys = new Set();
		const ship = { x: 380, y: 110, r: 10, a: -Math.PI / 2, vx: 0, vy: 0, cool: 0 };
		const state = {
			w: 760,
			h: 220,
			score: 0,
			alive: true,
			bullets: [],
			rocks: [],
			stars: Array.from({ length: 44 }, () => ({ x: Math.random() * 760, y: Math.random() * 220 })),
		};

		const makeRock = (size = 28, x = Math.random() * state.w, y = Math.random() * state.h) => ({
			x,
			y,
			size,
			vx: (Math.random() - 0.5) * 1.4,
			vy: (Math.random() - 0.5) * 1.4,
			a: Math.random() * Math.PI,
			spin: (Math.random() - 0.5) * 0.035,
			points: Array.from({ length: 8 }, (_, i) => {
				const angle = (i / 8) * Math.PI * 2;
				return { angle, radius: size * (0.72 + Math.random() * 0.4) };
			}),
		});

		const reset = () => {
			ship.x = state.w / 2;
			ship.y = state.h / 2;
			ship.vx = 0;
			ship.vy = 0;
			ship.a = -Math.PI / 2;
			ship.cool = 0;
			state.score = 0;
			state.alive = true;
			state.bullets = [];
			state.rocks = [makeRock(30, 80, 60), makeRock(24, state.w - 80, 90), makeRock(34, state.w - 160, state.h - 44)];
		};

		const wrap = (thing) => {
			if (thing.x < -40) thing.x = state.w + 40;
			if (thing.x > state.w + 40) thing.x = -40;
			if (thing.y < -40) thing.y = state.h + 40;
			if (thing.y > state.h + 40) thing.y = -40;
		};

		const resize = () => {
			const rect = canvas.getBoundingClientRect();
			const ratio = window.devicePixelRatio || 1;
			canvas.width = Math.round(rect.width * ratio);
			canvas.height = Math.round(rect.height * ratio);
			ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
			state.w = rect.width;
			state.h = rect.height;
		};

		const lineText = (text, x, y, align = "left") => {
			ctx.font = "12px monospace";
			ctx.textAlign = align;
			ctx.fillText(text, x, y);
		};

		const shoot = () => {
			if (!state.alive) {
				reset();
				return;
			}
			if (ship.cool > 0) return;
			state.bullets.push({
				x: ship.x + Math.cos(ship.a) * 13,
				y: ship.y + Math.sin(ship.a) * 13,
				vx: ship.vx + Math.cos(ship.a) * 5.8,
				vy: ship.vy + Math.sin(ship.a) * 5.8,
				life: 46,
			});
			ship.cool = 14;
		};

		const drawShip = () => {
			ctx.save();
			ctx.translate(ship.x, ship.y);
			ctx.rotate(ship.a);
			ctx.beginPath();
			ctx.moveTo(15, 0);
			ctx.lineTo(-10, -9);
			ctx.lineTo(-6, 0);
			ctx.lineTo(-10, 9);
			ctx.closePath();
			ctx.stroke();
			if (keys.has("ArrowUp") || keys.has("KeyW")) {
				ctx.beginPath();
				ctx.moveTo(-10, -5);
				ctx.lineTo(-19, 0);
				ctx.lineTo(-10, 5);
				ctx.stroke();
			}
			ctx.restore();
		};

		const drawRock = (rock) => {
			ctx.save();
			ctx.translate(rock.x, rock.y);
			ctx.rotate(rock.a);
			ctx.beginPath();
			rock.points.forEach((p, i) => {
				const x = Math.cos(p.angle) * p.radius;
				const y = Math.sin(p.angle) * p.radius;
				if (i === 0) ctx.moveTo(x, y);
				else ctx.lineTo(x, y);
			});
			ctx.closePath();
			ctx.stroke();
			ctx.restore();
		};

		const dist = (a, b) => Math.hypot(a.x - b.x, a.y - b.y);

		const update = () => {
			if (state.alive) {
				if (keys.has("ArrowLeft") || keys.has("KeyA")) ship.a -= 0.075;
				if (keys.has("ArrowRight") || keys.has("KeyD")) ship.a += 0.075;
				if (keys.has("ArrowUp") || keys.has("KeyW")) {
					ship.vx += Math.cos(ship.a) * 0.12;
					ship.vy += Math.sin(ship.a) * 0.12;
				}
				if (keys.has("Space")) shoot();

				ship.x += ship.vx;
				ship.y += ship.vy;
				ship.vx *= 0.992;
				ship.vy *= 0.992;
				ship.cool = Math.max(0, ship.cool - 1);
				wrap(ship);
			}

			for (const bullet of state.bullets) {
				bullet.x += bullet.vx;
				bullet.y += bullet.vy;
				bullet.life -= 1;
				wrap(bullet);
			}
			state.bullets = state.bullets.filter((b) => b.life > 0);

			for (const rock of state.rocks) {
				rock.x += rock.vx;
				rock.y += rock.vy;
				rock.a += rock.spin;
				wrap(rock);
			}

			for (const bullet of state.bullets) {
				for (const rock of state.rocks) {
					if (dist(bullet, rock) < rock.size) {
						bullet.life = 0;
						rock.dead = true;
						state.score += Math.round(40 - rock.size);
						if (rock.size > 18) {
							state.rocks.push(makeRock(rock.size * 0.58, rock.x, rock.y));
							state.rocks.push(makeRock(rock.size * 0.52, rock.x, rock.y));
						}
					}
				}
			}
			state.rocks = state.rocks.filter((rock) => !rock.dead);

			if (state.alive && state.rocks.some((rock) => dist(ship, rock) < rock.size + ship.r)) {
				state.alive = false;
			}

			if (state.rocks.length === 0) {
				state.rocks.push(makeRock(30), makeRock(26), makeRock(22));
			}
		};

		const draw = () => {
			ctx.clearRect(0, 0, state.w, state.h);
			ctx.strokeStyle = "#111827";
			ctx.fillStyle = "#111827";
			ctx.lineWidth = 2;

			for (const star of state.stars) {
				ctx.fillRect((star.x / 760) * state.w, (star.y / 220) * state.h, 1.5, 1.5);
			}

			lineText(`score ${state.score}`, 12, 18);
			lineText(state.alive ? "shoot rocks, don't become dust" : "ship deleted - space to reboot", state.w - 12, 18, "right");

			for (const bullet of state.bullets) {
				ctx.fillRect(bullet.x - 1, bullet.y - 1, 3, 3);
			}
			for (const rock of state.rocks) drawRock(rock);
			if (state.alive) drawShip();
			else {
				ctx.beginPath();
				ctx.moveTo(ship.x - 14, ship.y - 14);
				ctx.lineTo(ship.x + 14, ship.y + 14);
				ctx.moveTo(ship.x + 14, ship.y - 14);
				ctx.lineTo(ship.x - 14, ship.y + 14);
				ctx.stroke();
			}
		};

		const loop = () => {
			update();
			draw();
			requestAnimationFrame(loop);
		};

		window.addEventListener("resize", resize);
		window.addEventListener("keydown", (event) => {
			if (["ArrowUp", "ArrowLeft", "ArrowRight", "Space", "KeyW", "KeyA", "KeyD"].includes(event.code)) {
				event.preventDefault();
				keys.add(event.code);
			}
		});
		window.addEventListener("keyup", (event) => keys.delete(event.code));
		canvas.addEventListener("pointerdown", () => shoot());

		resize();
		reset();
		loop();
	}

	const arcadeStatus = document.getElementById("arcade-status");

	const getArcadeStatusForHour = (hour) => {
		if (hour >= 22 || hour < 6) return "eppy_mode";
		if (hour < 10) return "warmup_run";
		if (hour < 13) return "locked_in";
		if (hour < 17) return "active_sim";
		if (hour < 20) return "side_quest";
		return "low_power";
	};

	const updateArcadeStatus = () => {
		if (!arcadeStatus) return;
		const now = new Date();
		arcadeStatus.textContent = getArcadeStatusForHour(now.getHours());
		arcadeStatus.title = `Updated from local time: ${now.toLocaleTimeString([], {
			hour: "2-digit",
			minute: "2-digit",
		})}`;
	};

	updateArcadeStatus();
	setInterval(updateArcadeStatus, 60 * 1000);
</script>
