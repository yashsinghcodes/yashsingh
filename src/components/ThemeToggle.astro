<button
	id="theme-toggle"
	type="button"
	class="fixed right-3 top-3 z-50 border border-dashed border-gray-500 bg-gray-50 px-2 py-1 font-mono text-xs font-bold text-black hover:bg-black hover:text-white dark:border-zinc-500 dark:bg-zinc-900 dark:text-zinc-100 dark:hover:bg-zinc-100 dark:hover:text-zinc-950"
	aria-label="Toggle color theme"
	aria-pressed="false"
>
	<span data-theme-label>theme: light</span>
</button>

<script>
	const button = document.getElementById("theme-toggle");
	const label = button?.querySelector("[data-theme-label]");

	const getPreferredTheme = () => {
		const stored = localStorage.getItem("theme");
		if (stored === "dark" || stored === "light") return stored;
		return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
	};

	const setTheme = (theme) => {
		document.documentElement.classList.toggle("dark", theme === "dark");
		localStorage.setItem("theme", theme);
		if (label) label.textContent = `theme: ${theme}`;
		button?.setAttribute("aria-pressed", String(theme === "dark"));
	};

	setTheme(getPreferredTheme());

	button?.addEventListener("click", () => {
		const next = document.documentElement.classList.contains("dark") ? "light" : "dark";
		setTheme(next);
	});
</script>
