---
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Yash Singh</title>
		<script is:inline>
			const storedTheme = localStorage.getItem("theme");
			const preferredTheme =
				storedTheme === "dark" || storedTheme === "light"
					? storedTheme
					: window.matchMedia("(prefers-color-scheme: dark)").matches
						? "dark"
						: "light";
			document.documentElement.classList.toggle("dark", preferredTheme === "dark");
		</script>
	</head>
	<body class="bg-white text-gray-900 dark:bg-zinc-950 dark:text-zinc-100">
		<ThemeToggle />
		<!-- tailwindcss config which will center content horizontally -->
		<div class="flex flex-col items-center min-h-screen px-3 sm:px-6 md:px-12 lg:px-24 xl:px-80" id="container">
			<slot />
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
